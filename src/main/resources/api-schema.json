{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vega Agent Service API Schema",
  "description": "API contract for conflict resolution service",
  
  "definitions": {
    "ConflictResolutionRequest": {
      "type": "object",
      "required": ["filePath", "language", "base", "ours", "theirs", "startLine", "endLine"],
      "properties": {
        "filePath": {
          "type": "string",
          "description": "Path to the conflicted file",
          "minLength": 1,
          "maxLength": 500
        },
        "language": {
          "type": "string",
          "description": "Programming language (e.g., java, javascript, python)",
          "enum": ["java", "javascript", "python", "cpp", "c", "go", "rust", "typescript", "text"],
          "default": "text"
        },
        "base": {
          "type": "string",
          "description": "Base version (common ancestor)",
          "minLength": 0,
          "maxLength": 100000
        },
        "ours": {
          "type": "string",
          "description": "Our version (current branch)",
          "minLength": 0,
          "maxLength": 100000
        },
        "theirs": {
          "type": "string",
          "description": "Their version (target branch)",
          "minLength": 0,
          "maxLength": 100000
        },
        "startLine": {
          "type": "integer",
          "description": "Start line of conflict (1-based)",
          "minimum": 1,
          "maximum": 1000000
        },
        "endLine": {
          "type": "integer",
          "description": "End line of conflict (1-based)",
          "minimum": 1,
          "maximum": 1000000
        }
      }
    },
    "ConflictResolutionResponse": {
      "type": "object",
      "required": ["resolvedContent", "explanation", "safeToApply"],
      "properties": {
        "resolvedContent": {
          "type": "string",
          "description": "Resolved code content (conflict markers removed)",
          "minLength": 0,
          "maxLength": 100000
        },
        "explanation": {
          "type": "string",
          "description": "Brief explanation of resolution decision",
          "minLength": 0,
          "maxLength": 1000
        },
        "warnings": {
          "type": "array",
          "description": "List of warnings (empty if safe)",
          "items": {
            "type": "string",
            "maxLength": 500
          },
          "maxItems": 10
        },
        "safeToApply": {
          "type": "boolean",
          "description": "Whether resolution is safe to apply automatically"
        }
      }
    }
  },
  
  "paths": {
    "/api/agent/resolve": {
      "post": {
        "summary": "Resolve merge conflict using AI",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/definitions/ConflictResolutionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful resolution",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/definitions/ConflictResolutionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request (validation failed)"
          },
          "503": {
            "description": "Service unavailable (AI not configured)"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/agent/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "service": {"type": "string"},
                    "status": {"type": "string", "enum": ["READY", "NOT_CONFIGURED"]},
                    "available": {"type": "boolean"}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}


